@startuml
'http://plantuml.com/skinparam.html
skinparam handwritten true
skinparam monochrome true
skinparam packageStyle rect
skinparam defaultFontName FG Virgil
skinparam shadowing false

actor CustomerManager as Actor
participant RankCandidatesUI as UI <<presentation>>
participant ListApplicationController as ListApplicationController <<application>>
participant RankJobApplicationController as RankJobApplicationController <<application>>
participant GetApplicationService as Service <<service>>
participant JobApplication as Domain <<domain>>
database JobApplicationRepository as Repository <<repository>>

Actor --> UI: Rank Candidates
activate UI
    UI --> Actor: Ask Job Reference
    Actor --> UI: reference

    UI -> ListApplicationController: listApplicationsByJobOpeningId(reference)
    activate ListApplicationController
    ListApplicationController -> UI: job Applications
    deactivate ListApplicationController

    loop Rank candidates
        UI-> UI
        Actor -> UI: rank
        UI-> RankJobApplicationController: rankCandidatesForJobApplication(rank, email, reference)



    activate RankJobApplicationController
        RankJobApplicationController -> Service: getJobApplicationByCandidateEmailAndJobReference(email, reference)

            activate Service

                Service -> Repository: findApplicationByCandidateEmailAndJobReference(email, reference)
                    activate Repository
                        Repository -> Service: JobApplication
                    deactivate Repository
                    Service -> RankJobApplicationController: JobApplication
            deactivate Service

        RankJobApplicationController -> Domain: rankApplication(rank)
        RankJobApplicationController -> Repository: save(JobApplication)









    UI --> Actor: Display success message
end
deactivate UI
@enduml