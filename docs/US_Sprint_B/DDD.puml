'=== RequirmentProcess Aggregate ===
package RecruitmentProcess_Aggregate{
    Entity RecruitmentProcess <<Aggregate Root>>{
    }
    Enum Phases<<ValueObject>>{}
    Class Phase <<Value Object>> {}
    Class Period <<Value Object>> {}
    RecruitmentProcess --> "4...5" Phase
    Phase -->  "1" Phases
