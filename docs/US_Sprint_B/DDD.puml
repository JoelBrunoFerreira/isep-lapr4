}



'=== JobOpening Aggregate ===
package JobOpening_Aggregate{
    Entity JobOpening <<Aggregate Root>>{}
    Class JobReference <<Identity>><<ValueObject>>
    Class JobTitle <<Value Object>>{}
    Enum ContractType <<Enum>><<Value Object>> {}
    Enum WorkingMode <<Enum>><<Value Object>> {}
    Class Address <<Value Object>>{}
    Class NumberVacancies <<Value Object>>{}
    Class Description <<Value Object>> {}

    JobOpening --> "1" JobReference
    JobOpening --> "1" JobTitle
    JobOpening --> "1" ContractType
    JobOpening --> "1" WorkingMode
    JobOpening --> "1" Address
    JobOpening --> "1" NumberVacancies
    JobOpening --> "1" Description
}

'=== Company/Customer Aggregate ===
package Customer_Aggregate{

    Entity Customer <<Aggregate Root>>{
    }

    Class Email <<Identity>> <<Value Object>>{
    }
    Class Password <<Value Object>>{
    }
    Class Name <<Value Object>>{}
    Class Address <<Value Object>>{
        }
    Class Acronym <<Value Object>>{
    }

    Customer --> "1   " Email
