@startuml
'http://plantuml.com/skinparam.html
skinparam handwritten true
skinparam monochrome true
skinparam packageStyle rect
skinparam defaultFontName FG Virgil
skinparam shadowing false

actor CustomerManager as Actor
participant DisplayCandidateDataUI as UI <<presentation>>
participant GetCandidateController as CandidateController <<application>>

participant ListJobApplicationController as Controller <<application>>
database JobApplicationRepository as Repository <<repository>>




Actor --> UI: Display candidate data
activate UI
    UI --> Actor: Ask Candidate Email
    Actor --> UI: CandidateController Email

    UI -> CandidateController: getCandidateData(Email)

    activate CandidateController


        CandidateController -> UI: candidateDTO

    deactivate CandidateController

UI -> Controller: getJobApplicationsByCandidateEmail(email)

    activate Controller
        Controller -> Repository: getJobApplicationsByCandidateEmail(email)

        activate Repository
            Repository -> Controller: job applications
        deactivate Repository





        Controller -> UI: jobApplicationDTO
    deactivate Controller



    UI --> Actor: Show candidate data and its applications

deactivate UI







deactivate UI
@enduml